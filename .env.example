# HealthSenseAI Configuration

# Runtime mode
DEBUG=true
ENVIRONMENT=development

# JWT Signing Key (required in production; use a secure random hex string)
JWT_SECRET_KEY=replace-with-a-secure-random-secret

# Database URL
# Defaults to local SQLite file for out-of-the-box development.
# In production, replace with your PostgreSQL connection string, e.g.:
# DATABASE_URL=postgresql://user:password@localhost:5432/healthsense
DATABASE_URL=sqlite:///./healthmate.db

# Comma-separated list of allowed browser origins in production.
# Example: CORS_ORIGINS=https://healthsenseai.onrender.com,https://www.example.com
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,http://127.0.0.1:3000

# Google Gemini API Key
# Generate one at Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=
